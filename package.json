{
  "name": "pknut-opensearch-kit",
  "version": "0.1.0",
  "description": "A small suite for OpenSearch stack to build queries and connections faster",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "files": [
    "src",
    "tests",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "prepare": "husky install",
    "pretest": "npm run check && npm run lint",
    "test": "npm run base:test",
    "base:test": "jest --silent --runInBand --config jest.config.js",
    "check": "depcheck --ignores husky,jest,ts-jest",
    "lint": "standard",
    "lint:fix": "npm run lint -- --fix",
    "lint:staged": "lint-staged",
    "test:staged": "npm run base:test -- --findRelatedTests",
    "type-check": "tsc --noEmit",
    "build": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "git"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "depcheck": "^1.4.3",
    "husky": "^8.0.3",
    "jest": "^29",
    "lint-staged": "^13.3.0",
    "standard": "^17.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "standard": {
    "env": [
      "jest",
      "node"
    ]
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "@elastic/elasticsearch": "~7.10.0",
    "nltk-stopwords": "^1.0.3"
  }
}
